<h2>Admin Login</h2>

<form asp-action="Login" method="post">

    <input name="username"
           class="form-control"
           placeholder="Username" />

    <input type="password"
           name="password"
           class="form-control"
           placeholder="Password" />

    <br />

    <button class="btn btn-primary">

        Login

    </button>

</form>

<h4 style="color:red">

    @ViewBag.Message

</h4>
