<h2>Customer Login</h2>

<form asp-action="Login" method="post">

    <label>Email</label>

    <input name="email" class="form-control" />

    <label>Password</label>

    <input type="password"
           name="password"
           class="form-control" />

    <br />

    <button class="btn btn-primary">

        Login

    </button>

    <a asp-action="Register"
       class="btn btn-success">

        Register

    </a>

</form>

<h4 style="color:red">

    @ViewBag.Message

</h4>
